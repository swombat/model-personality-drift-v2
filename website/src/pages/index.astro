---
import BaseLayout from '../layouts/BaseLayout.astro';
import models from '../generated/models.json';

const completeModels = models
  .filter((model) => model.status !== 'redirect')
  .sort((a, b) => (b.release_date || '').localeCompare(a.release_date || '') || (a.display_name || a.model).localeCompare(b.display_name || b.model));
const labs = [...new Set(completeModels.map((model) => model.lab))].sort();
const families = [...new Set(completeModels.map((model) => model.family))].sort();
const statuses = [...new Set(completeModels.map((model) => model.status))].sort();
const totalSamples = completeModels.reduce((sum, model) => sum + model.published_samples, 0);
const base = import.meta.env.BASE_URL;

function priceLabel(value) {
  if (value === null || value === undefined) return 'unknown';
  if (value === 0) return 'free';
  return `$${value.toFixed(value < 0.01 ? 3 : 2)}/M`;
}

function speedLabel(value) {
  if (!value) return 'unknown';
  return `${Math.round(value)} tok/s`;
}

function speedSourceLabel(model) {
  if (model.speed_source === 'OpenRouter median') return 'OpenRouter';
  if (model.speed_source === 'sample median estimated') return 'sample estimate';
  return 'sample';
}

function releaseLabel(date) {
  if (!date) return 'Release date unavailable';
  return new Date(`${date}T00:00:00Z`).toLocaleDateString('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

function benchmarkTitle(model) {
  const score = model.benchmarks?.aaii;
  if (score === null || score === undefined) return '';
  const suffix = model.benchmarks?.estimated ? ' (estimated)' : '';
  return `Artificial Analysis Intelligence Index: ${score}${suffix}`;
}
---

<BaseLayout title="Model Personality Corpus">
  <section class="hero">
    <div>
      <h1>Browse the Model Personality Corpus</h1>
      <p class="lede">
        A static, generated browser for per-model personality cards, detailed qualitative analyses,
        values-probe summaries, and the freeflow and values samples behind them.
      </p>
    </div>
    <div class="stats-strip" aria-label="Corpus stats">
      <div class="stat"><b>{completeModels.length}</b><span>models</span></div>
      <div class="stat"><b>{labs.length}</b><span>labs</span></div>
      <div class="stat"><b>{totalSamples.toLocaleString()}</b><span>published samples</span></div>
    </div>
  </section>

  <section class="toolbar" aria-label="Model filters">
    <label>
      Search
      <input id="search" type="search" placeholder="Model, lab, summary..." />
    </label>
    <label>
      Lab
      <select id="labFilter">
        <option value="">All labs</option>
        {labs.map((lab) => <option value={lab}>{lab}</option>)}
      </select>
    </label>
    <label>
      Family
      <select id="familyFilter">
        <option value="">All families</option>
        {families.map((family) => <option value={family}>{family}</option>)}
      </select>
    </label>
    <label>
      Status
      <select id="statusFilter">
        <option value="">All statuses</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>
      Sort
      <select id="sortSelect">
        <option value="release">Newest release</option>
        <option value="model">Model</option>
        <option value="lab">Lab</option>
        <option value="price">Cheapest input</option>
        <option value="speed">Fastest reported</option>
        <option value="samples">Most samples</option>
      </select>
    </label>
  </section>

  <div class="section-title">
    <h2>Models</h2>
    <span id="resultCount" class="chip amber">{completeModels.length} shown</span>
  </div>

  <section id="modelGrid" class="model-grid">
    {completeModels.map((model) => (
      <article
        class="model-card"
        data-model={model.model}
        data-lab={model.lab}
        data-family={model.family}
        data-status={model.status}
        data-search={`${model.model} ${model.display_name || ''} ${model.lab} ${model.family} ${model.summary}`.toLowerCase()}
        data-release={model.release_date || ''}
        data-price={model.openrouter?.prompt_per_million ?? 999999}
        data-speed={model.speed_tokens_per_second ?? -1}
        data-samples={model.published_samples}
      >
        {model.benchmarks?.aaii !== undefined && (
          <a
            class="benchmark-score"
            href={model.benchmarks.url}
            title={benchmarkTitle(model)}
            aria-label={benchmarkTitle(model)}
            target="_blank"
            rel="noreferrer"
          >
            {model.benchmarks.aaii}
          </a>
        )}
        <a class="card-link" href={`${base}models/${model.model}/`}>
          {model.image_thumb && (
            <img
              class="card-thumb"
              src={`${base}${model.image_thumb}`}
              alt={`Painterly portrait evoking the personality of ${model.display_name || model.model}`}
              width="600"
              height="254"
              loading="lazy"
            />
          )}
          <div>
            <div class="card-kicker">
              <span class="chip">{model.lab}</span>
              <span class="chip green">{model.family}</span>
              <span class="chip amber">{model.status}</span>
            </div>
            <h2>{model.display_name || model.model}</h2>
            <p class="summary">{model.summary}</p>
            <p class="release-date">Released {releaseLabel(model.release_date)}</p>
          </div>
          <div>
            <div class="price-grid">
              <div class="price-box">
                <b>{priceLabel(model.openrouter?.prompt_per_million)}</b>
                <span>input tokens</span>
              </div>
              <div class="price-box">
                <b>{priceLabel(model.openrouter?.completion_per_million)}</b>
                <span>output tokens</span>
              </div>
            </div>
            <div class="price-grid">
              <div class="price-box">
                <div class="speed-stack">
                  <div class="speed-line">
                    <b>{speedLabel(model.speed_tokens_per_second)}</b>
                    <span class="speed-label">median</span>
                  </div>
                  {model.openrouter?.max_throughput && (
                    <div class="speed-line">
                      <b>{speedLabel(model.openrouter.max_throughput)}</b>
                      <span class="speed-label">recent max</span>
                    </div>
                  )}
                </div>
                <span>{speedSourceLabel(model)}</span>
              </div>
              <div class="price-box">
                <b>{model.published_samples.toLocaleString()}</b>
                <span>samples</span>
              </div>
            </div>
          </div>
        </a>
      </article>
    ))}
  </section>

  <p id="emptyState" class="empty hidden">No models match the current filters.</p>

  <script>
    const grid = document.getElementById('modelGrid');
    const cards = [...grid.querySelectorAll('.model-card')];
    const search = document.getElementById('search');
    const labFilter = document.getElementById('labFilter');
    const familyFilter = document.getElementById('familyFilter');
    const statusFilter = document.getElementById('statusFilter');
    const sortSelect = document.getElementById('sortSelect');
    const resultCount = document.getElementById('resultCount');
    const emptyState = document.getElementById('emptyState');

    function applyFilters() {
      const query = search.value.trim().toLowerCase();
      const lab = labFilter.value;
      const family = familyFilter.value;
      const status = statusFilter.value;
      let visible = 0;

      cards.forEach((card) => {
        const matches =
          (!query || card.dataset.search.includes(query)) &&
          (!lab || card.dataset.lab === lab) &&
          (!family || card.dataset.family === family) &&
          (!status || card.dataset.status === status);

        card.classList.toggle('hidden', !matches);
        if (matches) visible += 1;
      });

      const sorted = [...cards].sort((a, b) => {
        const sort = sortSelect.value;
        if (sort === 'price') return Number(a.dataset.price) - Number(b.dataset.price);
        if (sort === 'speed') return Number(b.dataset.speed) - Number(a.dataset.speed);
        if (sort === 'samples') return Number(b.dataset.samples) - Number(a.dataset.samples);
        if (sort === 'lab') return `${a.dataset.lab} ${a.dataset.model}`.localeCompare(`${b.dataset.lab} ${b.dataset.model}`);
        if (sort === 'release') return b.dataset.release.localeCompare(a.dataset.release) || a.dataset.model.localeCompare(b.dataset.model);
        return a.dataset.model.localeCompare(b.dataset.model);
      });

      sorted.forEach((card) => grid.appendChild(card));
      resultCount.textContent = `${visible} shown`;
      emptyState.classList.toggle('hidden', visible !== 0);
    }

    [search, labFilter, familyFilter, statusFilter, sortSelect].forEach((el) => {
      el.addEventListener('input', applyFilters);
      el.addEventListener('change', applyFilters);
    });
  </script>
</BaseLayout>
