---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../generated/models.json';

export function getStaticPaths() {
  return models
    .filter((model) => model.status !== 'redirect')
    .map((model) => ({ params: { model: model.model }, props: { model } }));
}

const { model } = Astro.props;
const base = import.meta.env.BASE_URL;
const markdown = model.analysis_markdown || '';
const withoutTitle = markdown.replace(/^# .+?\n+/, '');
const personalityMatch = withoutTitle.match(/(?:^|\n)## Personality card\n([\s\S]*?)(?=\n## |\n# |\s*$)/);
const personalityMarkdown = personalityMatch?.[1]?.trim() || '';
const analysisMarkdown = withoutTitle
  .replace(/(?:^|\n)## Personality card\n[\s\S]*?(?=\n## |\n# |\s*$)/, '')
  .trim();
const personalityHtml = marked.parse(personalityMarkdown);
const html = marked.parse(analysisMarkdown);

function priceLabel(value) {
  if (value === null || value === undefined) return 'unknown';
  if (value === 0) return 'free';
  return `$${value.toFixed(value < 0.01 ? 3 : 2)}/M`;
}

function speedLabel(value) {
  if (!value) return 'unknown';
  return `${Math.round(value)} tok/s`;
}
---

<BaseLayout title={`${model.model} | Model Personality Browser`} description={model.summary}>
  <section class="model-layout">
    <article class="article">
      <div class="card-kicker">
        <span class="chip">{model.lab}</span>
        <span class="chip green">{model.family}</span>
        <span class="chip amber">{model.status}</span>
      </div>
      <h1>{model.model}</h1>
      <p class="lede">{model.summary}</p>

      {personalityMarkdown && (
        <section class="personality-card">
          <h2>Personality card</h2>
          <div set:html={personalityHtml} />
        </section>
      )}

      <h2>Detailed analysis</h2>
      <div set:html={html} />
    </article>

    <aside class="side-panel" aria-label="Model metadata">
      <div class="panel">
        <h2>Model</h2>
        <div class="table-list">
          <div><b>Lab</b><br /><span>{model.lab}</span></div>
          <div><b>Family</b><br /><span>{model.family}</span></div>
          <div><b>Published freeflow samples</b><br /><span>{model.published_freeflow_samples.toLocaleString()}</span></div>
          <div><b>Published values samples</b><br /><span>{model.published_values_samples.toLocaleString()}</span></div>
        </div>
      </div>
      <div class="panel">
        <h2>OpenRouter</h2>
        <div class="table-list">
          <div><b>Matched model</b><br /><span>{model.openrouter?.id || 'No match'}</span></div>
          <div><b>Input</b><br /><span>{priceLabel(model.openrouter?.prompt_per_million)}</span></div>
          <div><b>Output</b><br /><span>{priceLabel(model.openrouter?.completion_per_million)}</span></div>
          <div>
            <b>Speed</b><br />
            <span class="speed-stack">
              <span class="speed-line">
                <b>{speedLabel(model.speed_tokens_per_second)}</b>
                <span class="speed-label">median</span>
              </span>
              {model.openrouter?.max_throughput && (
                <span class="speed-line">
                  <b>{speedLabel(model.openrouter.max_throughput)}</b>
                  <span class="speed-label">recent max</span>
                </span>
              )}
            </span>
          </div>
          <div><b>Speed source</b><br /><span>{model.speed_source || 'unknown'}</span></div>
          <div><b>Provider</b><br /><span>{model.openrouter?.provider || 'unknown'}</span></div>
        </div>
      </div>
      <a class="button-link" href={`${base}samples/${model.model}/`}>Browse samples</a>
    </aside>
  </section>
</BaseLayout>
