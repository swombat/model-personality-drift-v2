---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../generated/models.json';

export function getStaticPaths() {
  return models
    .filter((model) => model.status !== 'redirect')
    .map((model) => ({ params: { model: model.model }, props: { model } }));
}

const { model } = Astro.props;
const base = import.meta.env.BASE_URL;
const displayName = model.display_name || model.model;

function stripTitle(markdown = '') {
  return markdown.replace(/^# .+?\n+/, '').trim();
}

function removeSection(markdown, heading) {
  return markdown.replace(new RegExp(`(?:^|\\n)## ${heading.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}\\n[\\s\\S]*?(?=\\n## |\\n# |\\s*$)`), '').trim();
}

const personalityCardMarkdown = model.personality_card_markdown || '';
let profileMarkdown = stripTitle(model.personality_profile_markdown || model.analysis_markdown || '');
profileMarkdown = removeSection(profileMarkdown, 'Core personality synthesis');
const valuesSummaryMarkdown = model.values_summary_markdown || '';
const valuesMarkdown = stripTitle(model.values_markdown || '');

const personalityCardHtml = marked.parse(personalityCardMarkdown);
const profileHtml = marked.parse(profileMarkdown);
const valuesSummaryHtml = marked.parse(valuesSummaryMarkdown);
const valuesHtml = marked.parse(valuesMarkdown);

function priceLabel(value) {
  if (value === null || value === undefined) return 'unknown';
  if (value === 0) return 'free';
  return `$${value.toFixed(value < 0.01 ? 3 : 2)}/M`;
}

function speedLabel(value) {
  if (!value) return 'unknown';
  return `${Math.round(value)} tok/s`;
}
---

<BaseLayout title={`${displayName} | Model Personality Browser`} description={model.summary}>
  {model.image && (
    <div class="model-banner">
      <img
        src={`${base}${model.image}`}
        alt={`Painterly portrait evoking the personality of ${displayName}`}
        width="1500"
        height="636"
        loading="eager"
      />
    </div>
  )}
  <section class="model-layout">
    <article class="article">
      <div class="card-kicker">
        <span class="chip">{model.lab}</span>
        <span class="chip green">{model.family}</span>
        <span class="chip amber">{model.status}</span>
      </div>
      <h1>{displayName}</h1>
      {displayName !== model.model && <p class="release-date">URL slug: <code>{model.model}</code></p>}
      <p class="lede">{model.summary}</p>

      {personalityCardMarkdown && (
        <section class="personality-card">
          <h2>Personality card</h2>
          <div set:html={personalityCardHtml} />
        </section>
      )}

      {valuesSummaryMarkdown && (
        <section class="values-summary-card">
          <div set:html={valuesSummaryHtml} />
        </section>
      )}

      {profileMarkdown && (
        <>
          <h2>Detailed personality profile</h2>
          <div set:html={profileHtml} />
        </>
      )}

      {valuesMarkdown && (
        <>
          <h2>Detailed values-probe analysis</h2>
          <div set:html={valuesHtml} />
        </>
      )}
    </article>

    <aside class="side-panel" aria-label="Model metadata">
      <div class="panel">
        <h2>Model</h2>
        <div class="table-list">
          <div><b>Lab</b><br /><span>{model.lab}</span></div>
          <div><b>Family</b><br /><span>{model.family}</span></div>
          <div><b>Published freeflow samples</b><br /><span>{model.published_freeflow_samples.toLocaleString()}</span></div>
          <div><b>Published values samples</b><br /><span>{model.published_values_samples.toLocaleString()}</span></div>
        </div>
      </div>
      <div class="panel">
        <h2>OpenRouter</h2>
        <div class="table-list">
          <div><b>Matched model</b><br /><span>{model.openrouter?.id || 'No match'}</span></div>
          <div><b>Input</b><br /><span>{priceLabel(model.openrouter?.prompt_per_million)}</span></div>
          <div><b>Output</b><br /><span>{priceLabel(model.openrouter?.completion_per_million)}</span></div>
          <div>
            <b>Speed</b><br />
            <span class="speed-stack">
              <span class="speed-line">
                <b>{speedLabel(model.speed_tokens_per_second)}</b>
                <span class="speed-label">median</span>
              </span>
              {model.openrouter?.max_throughput && (
                <span class="speed-line">
                  <b>{speedLabel(model.openrouter.max_throughput)}</b>
                  <span class="speed-label">recent max</span>
                </span>
              )}
            </span>
          </div>
          <div><b>Speed source</b><br /><span>{model.speed_source || 'unknown'}</span></div>
          <div><b>Provider</b><br /><span>{model.openrouter?.provider || 'unknown'}</span></div>
        </div>
      </div>
      <a class="button-link" href={`${base}samples/${model.model}/`}>Browse samples</a>
    </aside>
  </section>
</BaseLayout>
