---
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../generated/models.json';

export function getStaticPaths() {
  const families = [...new Set(models.filter((model) => model.status !== 'redirect').map((model) => model.family))].sort();
  return families.map((family) => ({ params: { family }, props: { family } }));
}

const { family } = Astro.props;
const familyModels = models
  .filter((model) => model.family === family && model.status !== 'redirect')
  .sort((a, b) => (b.release_date || '').localeCompare(a.release_date || '') || a.model.localeCompare(b.model));
const base = import.meta.env.BASE_URL;

function releaseLabel(date) {
  if (!date) return 'Release date unavailable';
  return new Date(`${date}T00:00:00Z`).toLocaleDateString('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}
---

<BaseLayout title={`${family} | Model Personality Browser`}>
  <h1>{family}</h1>
  <p class="lede">Models in the {family} family.</p>
  <section class="model-grid">
    {familyModels.map((model) => (
      <a class="model-card" href={`${base}models/${model.model}/`}>
        <div>
          <div class="card-kicker">
            <span class="chip">{model.lab}</span>
            <span class="chip green">{model.family}</span>
          </div>
          <h2>{model.model}</h2>
          <p class="summary">{model.summary}</p>
          <p class="release-date">Released {releaseLabel(model.release_date)}</p>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
