---
import BaseLayout from '../../layouts/BaseLayout.astro';
import models from '../../generated/models.json';

export function getStaticPaths() {
  const labSlugs = new Map();
  for (const model of models) {
    if (model.status === 'redirect') continue;
    labSlugs.set(model.lab.toLowerCase().replaceAll(' ', '-').replaceAll('.', ''), model.lab);
  }
  return [...labSlugs.entries()].map(([slug, lab]) => ({ params: { lab: slug }, props: { lab } }));
}

const { lab } = Astro.props;
const labModels = models
  .filter((model) => model.lab === lab && model.status !== 'redirect')
  .sort((a, b) => (b.release_date || '').localeCompare(a.release_date || '') || a.model.localeCompare(b.model));
const base = import.meta.env.BASE_URL;

function releaseLabel(date) {
  if (!date) return 'Release date unavailable';
  return new Date(`${date}T00:00:00Z`).toLocaleDateString('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

function benchmarkTitle(model) {
  const score = model.benchmarks?.aaii;
  if (score === null || score === undefined) return '';
  const suffix = model.benchmarks?.estimated ? ' (estimated)' : '';
  return `Artificial Analysis Intelligence Index: ${score}${suffix}`;
}
---

<BaseLayout title={`${lab} | Model Personality Browser`}>
  <h1>{lab}</h1>
  <p class="lede">Models from {lab}, with personality summaries and sample links.</p>
  <section class="model-grid">
    {labModels.map((model) => (
      <article class="model-card">
        {model.benchmarks?.aaii !== undefined && (
          <a
            class="benchmark-score"
            href={model.benchmarks.url}
            title={benchmarkTitle(model)}
            aria-label={benchmarkTitle(model)}
            target="_blank"
            rel="noreferrer"
          >
            {model.benchmarks.aaii}
          </a>
        )}
        <a class="card-link" href={`${base}models/${model.model}/`}>
          <div>
            <div class="card-kicker">
              <span class="chip">{model.lab}</span>
              <span class="chip green">{model.family}</span>
            </div>
            <h2>{model.model}</h2>
            <p class="summary">{model.summary}</p>
            <p class="release-date">Released {releaseLabel(model.release_date)}</p>
          </div>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
