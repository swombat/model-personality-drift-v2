---
import '../styles/global.css';

const { title = 'Model Personality Corpus', description = 'Browse model personality analyses, cards, profiles, and source samples.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="topbar">
        <div class="topbar-inner">
          <a class="brand" href={base}>
            <strong>Model Personality Corpus</strong>
            <span>Analysis corpus and model cards</span>
          </a>
          <nav class="nav" aria-label="Primary">
            <a href={base}>Models</a>
            <a href={`${base}labs/`}>Labs</a>
            <a href={`${base}families/`}>Families</a>
          </nav>
        </div>
      </header>
      <main class="page">
        <slot />
      </main>
    </div>
  </body>
</html>
